# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# NOTE: The MediaMaxxing API key is stored as a Supabase secret,
# NOT in this file. Set it via:
#   supabase secrets set MEDIAMAXXING_API_KEY=your-key-here
#
# IMPORTANT: Disable email confirmations in Supabase Auth settings
# so users can sign up and use the app immediately.
